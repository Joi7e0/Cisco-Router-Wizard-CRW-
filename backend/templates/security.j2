!
service password-encryption
{% if enable_secret %}
enable algorithm-type scrypt secret {{ enable_secret }}
{% endif %}
{% if console_password %}
line console 0
 password {{ console_password }}
 login
 exit
!
{% endif %}
{% if enable_ssh %}
ip domain-name {{ domain_name }}
username {{ admin_username }} privilege 15 algorithm-type scrypt secret {{ admin_password }}
crypto key generate rsa modulus 2048
ip ssh version 2
line vty 0 4
 transport input ssh
 login local
 exit
!
{% endif %}

